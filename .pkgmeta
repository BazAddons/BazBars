package-as: BazBars
ignore:
  - .git
  - .gitignore
  - .pkgmeta
  - LICENSE
  # Marketing image lives in the repo root so the README + CurseForge
  # description can link to it via a raw.githubusercontent.com URL.
  # No business being in the in-game install - the BigWigsMods packager
  # bundles every non-ignored file by default, so without this
  # exclusion the ZIP balloons on every release.
  - screenshot.png
